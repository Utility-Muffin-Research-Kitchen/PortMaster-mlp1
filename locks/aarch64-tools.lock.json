{
  "schema": 1,
  "kind": "source-built-native-tools",
  "architecture": "aarch64",
  "tools": {
    "rsync": {
      "name": "rsync",
      "version": "3.2.7",
      "source": {
        "url": "https://download.samba.org/pub/rsync/src/rsync-3.2.7.tar.gz",
        "size": 1149787,
        "sha256": "4e7d9d3f6ed10878c58c5fb724a67dacf4b6aac7340b13e488fb2dc41346f2bb"
      },
      "license": {
        "spdx": "GPL-3.0-or-later",
        "source_path": "COPYING",
        "installed_path": "LICENSES/rsync/COPYING"
      },
      "configure": [
        "--host=aarch64-buildroot-linux-gnu",
        "--prefix=/usr",
        "--disable-md2man",
        "--disable-ipv6",
        "--disable-openssl",
        "--disable-xxhash",
        "--disable-zstd",
        "--disable-lz4",
        "--disable-acl-support",
        "--disable-xattr-support",
        "--disable-iconv",
        "--with-included-popt",
        "--with-included-zlib"
      ],
      "installed_path": "compat/tools/aarch64/bin/rsync"
    },
    "zip": {
      "name": "zip",
      "version": "3.0",
      "source": {
        "url": "https://downloads.sourceforge.net/infozip/zip30.tar.gz",
        "size": 1118845,
        "sha256": "f0e8bb1f9b7eb0b01285495a2699df3a4b766784c1765a8f1aeedf63c0806369"
      },
      "license": {
        "spdx": "Info-ZIP",
        "source_path": "LICENSE",
        "installed_path": "LICENSES/zip/LICENSE"
      },
      "build": [
        "make",
        "-f",
        "unix/Makefile",
        "generic"
      ],
      "installed_path": "compat/tools/aarch64/bin/zip"
    }
  }
}
